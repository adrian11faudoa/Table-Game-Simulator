# ============================
# Unreal Engine 5 — InfinityTable
# ============================

# Visual Studio / Rider intermediate files
.vs/
.vsconfig
*.sln
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
.idea/
*.iws

# Compiled binaries / intermediate build artifacts
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
.ue4/
.ue5/

# Mods loaded at runtime (user-generated content; not part of source)
Saved/Mods/

# Packaged/cooked builds
Build/Windows/
Build/Linux/

# macOS
.DS_Store

# Editor crash logs
*.upk
*.crash

# Generated project files
*.xcodeproj
*.xcworkspace
CMakeLists.txt
cmake-build-*/

# ThirdParty fetched binaries (downloaded via install.bat/install.sh,
# not redistributed in source control)
ThirdParty/lua54/include/*.h
ThirdParty/lua54/lib/*.lib
ThirdParty/lua54/lib/*.a
ThirdParty/sol2/include/sol/
ThirdParty/sol2/include/sol.hpp
ThirdParty/sqlite3/sqlite3.c
ThirdParty/sqlite3/sqlite3.h

# Auto-generated by InfinityTable.Build.cs to compile the SQLite amalgamation
Source/InfinityTable/ThirdParty/sqlite3_amalgamation.cpp

# Fetched plugin (downloaded via ThirdParty/install.bat or install.sh)
Plugins/glTFRuntime/

# User mods dropped at runtime (not part of source)
Saved/Mods/

# Local environment / secrets
.env
*.local.ini
AWS/*.pem
AWS/credentials.json

# SQLite local save database
*.db
*.db-journal
*.db-wal

# OS-generated files
Thumbs.db
desktop.ini
